# Server Configuration
PORT=3000
JWT_SECRET=supersecretkeychangeinprod

# LLM API Key (Groq - free at https://console.groq.com/keys)
# If missing, the app falls back to rule-based compatibility scoring
GROQ_API_KEY=

# SMTP Mail Configuration (optional - defaults to console logger)
# Any free-tier email service works (e.g., Mailtrap, Brevo, Gmail SMTP)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@flatmatefinder.com
